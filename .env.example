# mac-remote-terminal — example bridge env file.
# Copy to `.env` and edit. The bridge auto-loads `.env` from the working
# directory at boot. Existing shell exports always WIN over .env values
# (so you can override any key on the command line).
#
# Override the .env path with `BRIDGE_ENV_FILE=/abs/path/to/some.env`.

# === Phase 1 — auth + bind ===

# Required. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIDGE_TOKEN=

# WebSocket / HTTP port. Default 8765.
# BRIDGE_PORT=8765

# Optional explicit bind host. Default = first non-loopback Tailscale IPv4.
# BRIDGE_BIND_HOST=100.x.x.x

# === Phase 3 — filesystem allowlist ===

# Comma-separated list of dirs the bridge will spawn inside / read from.
# Falls back to $HOME if unset.
BRIDGE_ALLOWED_DIRS=/Volumes/WDSSD/Code

# === Phase 2 — transcript retention ===

# Days to keep transcript JSONLs. 0 = never delete. Default 30.
# BRIDGE_TRANSCRIPT_RETENTION_DAYS=30

# === Phase 5 — session registry ===

# Defaults to .bridge/sessions.json. Override to share registry across instances.
# BRIDGE_SESSIONS_FILE=.bridge/sessions.json

# === Phase 6 — profiles ===

# Defaults to .bridge/profiles.json.
# BRIDGE_PROFILES_FILE=.bridge/profiles.json

# === Phase 6 — file search cap (@-tag picker) ===

# Max files walked per session. Default 5000.
# BRIDGE_FILE_SEARCH_CAP=5000

# === Phase 6 — Telegram notifications (all optional; absent disables feature) ===

# See docs/setup/telegram-bot.md
# BRIDGE_TELEGRAM_BOT_TOKEN=
# BRIDGE_TELEGRAM_CHAT_ID=

# Threshold for notification (ms). Default 180000 (3 min). Set 0 to notify on every turn.
# BRIDGE_NOTIFY_MIN_DURATION_MS=180000

# Public URL included in Telegram messages. Useful when accessing via Tailscale on phone.
# BRIDGE_PUBLIC_URL=http://100.x.x.x:8765
